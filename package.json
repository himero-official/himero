{
  "name": "himero",
  "version": "1.0.7",
  "license": "SEE LICENSE IN LICENSE",
  "description": "Zero-config error tracking and AI-powered diagnosis for JavaScript applications — Next.js, React, Node.js, Express, NestJS",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.mjs",
      "require": "./dist/react.js"
    },
    "./nextjs": {
      "types": "./dist/nextjs.d.ts",
      "import": "./dist/nextjs.mjs",
      "require": "./dist/nextjs.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.mjs",
      "require": "./dist/node.js"
    },
    "./express": {
      "types": "./dist/express.d.ts",
      "import": "./dist/express.mjs",
      "require": "./dist/express.js"
    },
    "./nestjs": {
      "types": "./dist/nestjs.d.ts",
      "import": "./dist/nestjs.mjs",
      "require": "./dist/nestjs.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^20.19.37",
    "@types/react": "^18.3.28",
    "tsup": "^8.0.0",
    "typescript": "^5.9.3"
  },
  "keywords": [
    "error-tracking",
    "monitoring",
    "logging",
    "error-monitoring",
    "nextjs",
    "crash-reporting",
    "ai-diagnostics",
    "zero-config",
    "breadcrumbs"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/himero-official/himero.git"
  },
  "homepage": "https://himero.app",
  "bugs": {
    "url": "https://github.com/himero-official/himero/issues"
  }
}